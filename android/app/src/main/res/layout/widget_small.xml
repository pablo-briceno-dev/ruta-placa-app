<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="4dp"/>

        <!-- ✅ Agregar ID para poder ocultarlo en modo compacto -->
        <TextView
            android:id="@+id/ws_app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RutaPlaca"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/ws_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bogotá"
            android:textColor="#888888"
            android:textSize="9sp"/>

    </LinearLayout>

    <!-- Fila de chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Chip hoy -->
        <LinearLayout
            android:id="@+id/ws_chip_today"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_green"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/ws_today_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textColor="#1DB954"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/ws_today_digits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Libre"
                android:textColor="#1DB954"
                android:textSize="9sp"
                android:layout_marginTop="1dp"
                android:gravity="center"
                android:maxLines="1"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Chip día 2 -->
        <LinearLayout
            android:id="@+id/ws_chip_day2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_gray"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/ws_day2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mié"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/ws_day2_digits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Libre"
                android:textColor="#AAAAAA"
                android:textSize="9sp"
                android:layout_marginTop="1dp"
                android:gravity="center"
                android:maxLines="1"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Chip día 3 -->
        <LinearLayout
            android:id="@+id/ws_chip_day3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_gray"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/ws_day3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jue"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/ws_day3_digits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1·2·3"
                android:textColor="#AAAAAA"
                android:textSize="9sp"
                android:layout_marginTop="1dp"
                android:gravity="center"
                android:maxLines="1"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>